  "sections": [
    {
      "name": "Prematch",
      "fields": [
        {
          "title": "Scouter Initials",
          "description": "Enter the initials of the scouter.",
          "type": "text",
          "required": true,
          "code": "scouter",
          "formResetBehavior": "preserve",
          "defaultValue": ""
        },
        {
          "title": "Match Number",
          "description": "Enter the match number.",
          "type": "number",
          "required": true,
          "code": "matchNumber",
          "formResetBehavior": "increment",
          "defaultValue": 0
        },
        {
          "title": "Team Number",
          "description": "The team number of the robot you're scouting.",
          "type": "number",
          "required": true,
          "code": "teamNumber",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "min": 0,
          "max": 19999
        },
        {
          "title": "Starting Position",
          "description": "The starting position of the robot.",
          "type": "select",
          "required": true,
          "code": "Prsp",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "choices": {
            "R1": "Outpost Side",
            "R2": "Middle",
            "R3": "Depot Side"
          }
        }
      ]
    },
    {
      "name": "Autonomous",
      "fields": [
        {
          "title": "Autonomous Path",
          "description": "Draw the robot's path for auto.",
          "type": "image-draw",
          "required": true,
          "code": "autoPathing",
          "disabled": false,
          "formResetBehavior": "reset",
          "defaultValue": []
        },
        {
          "title": "Moved?",
          "description": "Check if the robot moved during autonomous.",
          "type": "boolean",
          "required": false,
          "code": "Mved",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Auto Climbed Tower",
          "type": "select",
          "required": true,
          "code": "Auto Climbed Tower",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "choices": {
            "1": "Level 1",
            "2": "Level 2",
            "3": "Level 3",
            "No": "Didn't Climb",
            "F": "Failed Climb",
            " ": "Unsure"
          }
        },
        {
          "title": "Auto Climb Side",
          "type": "select",
          "required": false,
          "code": "Auto Climb Side",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "choices": {
            "L": "Depot Side (Left)",
            "R": "Outpost Side (Right)",
            " ": "Unsure"
          }
        },
        {
          "title": "Auto Foul",
          "description": "How often did they get a foul, ie: firing fuel outside of field",
          "type": "counter",
          "required": false,
          "code": "auf",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "min": 0,
          "step": 1
        }
      ]
    },
    {
      "name": "Teleop",
      "fields": [
        {
          "title": "Robot Lob Shots",
          "description": "The number of times a robot shoots a lob shot",
          "type": "counter",
          "required": false,
          "code": "LF",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "min": 0,
          "step": 1
        },
        {
          "title": "Played Defense?",
          "type": "boolean",
          "required": false,
          "code": "CFPDT",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Fed Human Player?",
          "description": "Did they push fuel into the outpost?",
          "type": "boolean",
          "required": false,
          "code": "fedHumanPlayer",
          "formResetBehavior": "reset",
          "defaultValue": false
        }
      ]
    },
    {
      "name": "Endgame",
      "fields": [
        {
          "title": "Endgame Climbed Tower",
          "type": "select",
          "required": true,
          "code": "Endgame Climbed Tower",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "choices": {
            "1": "Level 1",
            "2": "Level 2",
            "3": "Level 3",
            "No": "Didn't Climb",
            "F": "Failed Climb",
            " ": "Unsure"
          }
        },
        {
          "title": "Endgame Climb Side",
          "type": "select",
          "required": false,
          "code": "Endgame Climb Side",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "choices": {
            "L": "Depot Side (Left)",
            "R": "Outpost Side (Right)",
            " ": "Unsure"
          }
        },
        {
          "title": "Tipped/Fell Over?",
          "type": "boolean",
          "required": false,
          "code": "TFOT",
          "formResetBehavior": "reset",
          "defaultValue": false
        }
      ]
    },
    {
      "name": "Postmatch",
      "fields": [
        {
          "title": "Intake",
          "description": "How did the robot intake?",
          "type": "select",
          "required": true,
          "code": "robotIntake",
          "formResetBehavior": "reset",
          "defaultValue": " ",
          "choices": {
            "G": "Ground",
            "O": "Outpost",
            " ": "Unsure"
          }
        },
        {
          "title": "Over/Under?",
          "description": "Did they go over the bump or under the trench?",
          "type": "select",
          "required": true,
          "code": "over/under",
          "formResetBehavior": "reset",
          "defaultValue": "No",
          "choices": {
            "O": "Over the Bump",
            "U": "Under the Trench",
            "B": "Both",
            "N": "Neither",
            " ": "Unsure"
          }
        },
        {
          "title": "Comments",
          "description": "Where are they shooting from? \n Go to the depot in auto? \n Did they play defence? \n Human player accuracy? \n Robot stability? Tippy? Stable? \n Penalties? [code] \n Shots in inactive hub (count as miss) \n Getting beached? \n Tank or swerve? \n Interesting mechanisms/shapes?",
          "type": "text",
          "required": true,
          "code": "co",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "min": 0,
          "max": 500
        }
      ]
    }
  ]
}